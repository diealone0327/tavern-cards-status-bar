  "type": "object",
  "properties": {
    "系统": {
      "default": {},
      "type": "object",
      "properties": {
        "当前阶段": {
          "default": "亲情",
          "type": "string",
          "enum": [
            "亲情",
            "暧昧",
            "乱伦"
          ]
        },
        "当前场景": {
          "default": "客厅",
          "type": "string"
        }
      }
    },
    "艳母": {
      "default": {},
      "type": "object",
      "properties": {
        "好感度": {
          "default": 30,
          "type": "number"
        },
        "欲望": {
          "default": 5,
          "type": "number"
        },
        "沉沦": {
          "default": 0,
          "type": "number"
        },
        "发情": {
          "default": 0,
          "type": "number"
        }
      }
    }
  }
}