    "随机NPC关系": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "string",
        "enum": [
          "友好",
          "冷漠",
          "敌对"
        ]
      }
