    "秘境": {
      "default": {},
      "type": "object",
      "properties": {
        "当前活跃秘境": {
          "default": "",
          "type": "string"
        },
        "开启倒计时": {
          "default": "",
          "type": "string"
        },
        "已探索秘境": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "秘境列表": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "任务": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "状态": {
            "default": "未开始",
            "type": "string",
            "enum": [
              "未开始",
              "进行中",
              "已完成",
              "失败"
            ]
          },
          "来源": {
            "default": "",
            "type": "string"
          },
          "描述": {
            "default": "",
            "type": "string"
          }
        }
      }
    }
