{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "系统": {
      "default": {},
      "type": "object",
      "properties": {
        "当前时间": {
          "default": "第1日·清晨",
          "type": "string"
        },
        "当前地点": {
          "default": "青云宗·杂役院",
          "type": "string"
        },
        "剧情阶段": {
          "default": "初遇",
          "type": "string"
        }
      }
    },
    "user": {
      "default": {},
      "type": "object",
      "properties": {
        "修为境界": {
          "default": "练气",
          "type": "string",
          "enum": [
            "练气",
            "筑基",
            "金丹",
            "元婴",
            "化神",
            "合体",
            "大乘",
            "渡劫"
          ]
        },
        "修为进度": {
          "default": 0,
          "type": "number"
