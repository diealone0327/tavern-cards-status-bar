          "enum": [
            "杂役弟子",
            "外门弟子",
            "内门弟子",
            "真传弟子",
            "长老"
          ]
        },
        "持有物品": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "number"
          }
        },
        "物品分类": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "储物袋": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "number"
          }
        },
        "储物袋分类": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "仓库": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "number"
          }
        },
        "仓库分类": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "已学功法": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "当前装备的功法": {
          "default": "",
          "type": "string"
        },
        "穿着": {
          "default": "灰色破旧短褐",
          "type": "string"
        },
        "身体状况": {
          "default": "健康",
          "type": "string",
          "enum": [
            "健康",
            "轻伤",
            "重伤",
            "中毒",
            "濒危"
          ]
        }
      }
    },
    "聚宝盆": {
      "default": {},
      "type": "object",
      "properties": {
        "冷却状态": {
          "default": true,
          "type": "boolean"
        },
        "盆内物品": {
          "default": "",
          "type": "string"
        },
        "剩余时间": {
          "default": "",
          "type": "string"
        },
        "_复制记录": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "物品名": {
                "type": "string"
              },
              "品质": {
                "type": "string"
              },
              "日期": {
                "type": "string"
              }
            },
            "required": [
              "物品名",
              "品质",
              "日期"
            ]
          }
        }
      }
    },
    "宗门": {
      "default": {},
      "type": "object",
      "properties": {
